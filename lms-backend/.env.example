# SMTP (use SendGrid/SMTP provider or Gmail SMTP via app password)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false            # true if port 465
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Email sender
FROM_EMAIL="LMS FOR LEARNING <no-reply@yourdomain.com>"

# Public base URL where backend and verify page are hosted (no trailing slash)
# Example: https://mylms.onrender.com
BASE_URL=http://localhost:3000

# Directory to save generated PDFs (relative to project)
CERT_DIR=./generated_certificates
